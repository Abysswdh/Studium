{
  "manifest_version": 3,
  "name": "Studium Now Playing Bridge",
  "version": "0.1.0",
  "description": "Expose Spotify / YouTube Music now playing state + controls to Studium via window messaging.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["https://open.spotify.com/*", "https://music.youtube.com/*", "http://localhost/*", "http://127.0.0.1/*", "https://*.vercel.app/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/providers/spotify.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["src/providers/ytmusic.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*", "https://*.vercel.app/*"],
      "js": ["src/bridge/studium-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}

